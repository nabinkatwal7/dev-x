{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevForge",
  "version": "0.1.0",
  "identifier": "dev.devforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevForge",
        "theme": "Dark",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 760,
        "visible": false,
        "maximized": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "decorations": false,
        "center": true,
        "hiddenTitle": true,
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
